{
  "expo": {
    "name": "voice-vault",
    "slug": "voice-vault",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/voice-vault-play-store.png",
    "scheme": "voice-vault",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/voice-vault-app-store.png",
      "bundleIdentifier": "com.vitorvalem.voicevault",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.vitorvalem.voicevault",
      "icon": "./assets/voice-vault-play-store.png",
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/voice-vault-favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0d0b1a",
          "android": {
            "image": "./assets/voice-vault-logo-dark.svg",
            "imageWidth": 76
          }
        }
      ],
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "react-native",
          "organization": "vitorvalem"
        }
      ],
      "expo-status-bar",
      "expo-secure-store",
      "expo-sharing",
      "expo-notifications",
      "expo-localization",
      "expo-font",
      "expo-image"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "fd37b3d6-2cd9-47b0-81da-4567dfa910c5"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0
    }
  }
}
